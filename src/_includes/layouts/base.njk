<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} | {% endif %}Steadfast Doula Care</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}Steadfast Doula Care — compassionate birth doula services by Vanessa Culy.{% endif %}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400&display=swap" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo" aria-label="Steadfast Doula Care — Home">
          <img src="/assets/logo.svg" alt="" class="logo-image" />
          <span class="logo-text">Steadfast Doula Care</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Open navigation menu">
            <span></span><span></span><span></span>
          </button>
          <ul id="nav-menu" class="nav-menu">
            <li><a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a></li>
            <li><a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>About</a></li>
            <li><a href="/services/" {% if page.url == "/services/" %}aria-current="page"{% endif %}>Services</a></li>
            <li><a href="/contact/" class="btn-nav" {% if page.url == "/contact/" %}aria-current="page"{% endif %}>Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; <span id="copyright-year"></span><noscript>2026</noscript> Steadfast Doula Care. All rights reserved.</p>
        <p>Serving families with heart and dedication.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const menu = document.querySelector('.nav-menu');
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        menu.classList.toggle('is-open');
      });

      const yearEl = document.getElementById('copyright-year');
      if (yearEl) {
        yearEl.textContent = String(new Date().getFullYear());
      }
    </script>
  </body>
</html>
